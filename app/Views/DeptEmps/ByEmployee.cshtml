@model List<SistemaNomina.Models.DeptEmp>

    <div class="container-fluid mt-4">
        <div class="row mb-3">
            <div class="col-md-6">
                <h2>Asignaciones - @ViewBag.Employee.FirstName @ViewBag.Employee.LastName</h2>
            </div>
            <div class="col-md-6 text-end">
                <button type="button" class="btn btn-primary" id="btnCreateAssign">Agregar Asignacion</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary">Volver</a>
            </div>
        </div>

        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Departamento</th>
                    <th>Desde</th>
                    <th>Hasta</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DeptNo</td>
                    <td>@item.FromDate</td>
                    <td>@(string.IsNullOrEmpty(item.ToDate) ? "Vigente" : item.ToDate)</td>
                    <td>
                        @if (string.IsNullOrEmpty(item.ToDate))
                        {
                        <span class="badge bg-success">Activo</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="modal fade" id="assignModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Agregar Asignacion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="modalBody"></div>
            </div>
        </div>
    </div>

    @section Scripts {
                   <script>
    const modal = new bootstrap.Modal(document.getElementById('assignModal'), {});
    const empNo = @ViewBag.Employee.EmpNo;

    document.getElementById('btnCreateAssign').addEventListener('click', function() {
        fetch(`/DeptEmps/Create?empNo=${empNo}`)
            .then(response => response.text())
            .then(html => {
                document.getElementById('modalBody').innerHTML = html;
                modal.show();
            });
    });

    function saveAssignment() {
        const deptNo = document.getElementById('deptNo').value;
        const fromDate = document.getElementById('fromDate').value;

        fetch(`@Url.Action("Create")`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: `empNo=${empNo}&deptNo=${deptNo}&fromDate=${fromDate}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                modal.hide();
                location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        });
    }
                   </script>
    }

@model List<SistemaNomina.Models.Employees>

    @{
    ViewData["Title"] = "Empleados";
    }

    <div class="container-fluid mt-4">
        <div class="row mb-3">
            <div class="col-md-6">
                <h2>Gestion de Empleados</h2>
            </div>
            <div class="col-md-6 text-end">
                <button type="button" class="btn btn-primary" id="btnCreateEmp">
                    Crear Empleado
                </button>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Cedula</th>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>Genero</th>
                            <th>Correo</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var emp in Model)
                        {
                        <tr>
                            <td>@emp.EmpNo</td>
                            <td>@emp.Ci</td>
                            <td>@emp.FirstName</td>
                            <td>@emp.LastName</td>
                            <td>@emp.Gender</td>
                            <td>@emp.Correo</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-warning" onclick="editEmployee(@emp.EmpNo)">Editar</button>
                                <button type="button" class="btn btn-sm btn-danger" onclick="deleteEmployee(@emp.EmpNo)">Eliminar</button>
                            </td>
                        </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">No hay empleados registrados.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="employeeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Crear Empleado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="modalBody"></div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
    const modal = new bootstrap.Modal(document.getElementById('employeeModal'), {});
    document.getElementById('btnCreateEmp').addEventListener('click', function() {
        document.getElementById('modalTitle').textContent = 'Crear Empleado';
        loadFormCreate();
    });
    function loadFormCreate() {
        fetch('@Url.Action("Create", "Employees")')
            .then(response => response.text())
            .then(html => {
                document.getElementById('modalBody').innerHTML = html;
                modal.show();
            });
    }
    function editEmployee(id) {
        document.getElementById('modalTitle').textContent = 'Editar Empleado';
        fetch(`@Url.Action("Edit", "Employees")/${id}`)
            .then(response => response.text())
            .then(html => {
                document.getElementById('modalBody').innerHTML = html;
                modal.show();
            });
    }
    function saveEmployee() {
        const form = document.getElementById('empForm');
        const formData = new FormData(form);
        const url = form.action;
        const method = form.method;
        fetch(url, { method: method, body: formData })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    modal.hide();
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => alert('Error: ' + error));
    }
    function deleteEmployee(id) {
        if (confirm('Está seguro de que desea eliminar este empleado?')) {
            fetch(`@Url.Action("Delete", "Employees")/${id}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }
    }
        </script>
    }
